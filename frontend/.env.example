# URL of the Deenly Node API (must match where the backend listens). Next.js often runs on :3000 while the API uses another port (e.g. 8080).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1
# Production (Railway): set the same in Vercel/hosting env, not only in this file.
# NEXT_PUBLIC_API_BASE_URL=https://deenly-production.up.railway.app/api/v1
NEXT_PUBLIC_MEDIA_PUBLIC_BASE_URL=
NEXT_PUBLIC_ADMIN_OWNER_EMAIL=you@example.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# Social UI icons: `remote` = Figma MCP CDN (URLs can expire; good for quick dev).
# `local` = serve from /public/icons/social/*.svg — recommended for production (see public/icons/social/README.txt).
# NEXT_PUBLIC_SOCIAL_ICONS_MODE=local

# Search "Near me" uses OpenStreetMap embed + /businesses/near; no map API key required for the default UI.
# Optional browser crash reporting (production). NEXT_PUBLIC_SENTRY_SEND_IN_DEV=1 to test in dev.
# NEXT_PUBLIC_SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_SEND_IN_DEV=1
