{
  "name": "deenly-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Backend API for Deenly Muslim social platform",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "lint": "eslint \"src/**/*.js\" \"test/**/*.js\"",
    "test": "jest --runInBand",
    "test:integration:local": "bash scripts/run-integration-local.sh",
    "verify:env-contract": "node scripts/verify-env-and-contract.js",
    "verify:deploy-env-parity": "node scripts/verify-deploy-env-parity.js",
    "verify:release-gates": "node scripts/verify-release-gates.js",
    "ops:check-metrics": "node scripts/check-ops-metrics.js",
    "migrate": "node-pg-migrate up --config-file ./node-pg-migrate.config.json",
    "migrate:create": "node-pg-migrate create --config-file ./node-pg-migrate.config.json",
    "migrate:up": "node-pg-migrate up --config-file ./node-pg-migrate.config.json",
    "migrate:down": "node-pg-migrate down --config-file ./node-pg-migrate.config.json",
    "postinstall": "npm run build --prefix ../shared/rewards"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@deenly/rewards-shared": "file:../shared/rewards",
    "@aws-sdk/client-s3": "^3.726.1",
    "@aws-sdk/s3-request-presigner": "^3.726.1",
    "adhan": "^4.4.3",
    "argon2": "^0.41.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "expo-server-sdk": "^6.1.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "plaid": "^38.1.0",
    "stripe": "^20.4.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "eslint": "^9.14.0",
    "jest": "^29.7.0",
    "node-pg-migrate": "^7.9.1",
    "supertest": "^7.0.0"
  }
}
