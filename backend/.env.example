NODE_ENV=production
PORT=3000
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DB_SSL_MODE=require
CORS_ORIGINS=https://your-web-app-domain.com
JWT_ACCESS_SECRET=replace-with-very-long-random-secret
JWT_REFRESH_SECRET=replace-with-very-long-random-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
LOG_LEVEL=info
TRUST_PROXY=true
