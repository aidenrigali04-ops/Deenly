NODE_ENV=production
PORT=3000
# Listen address (default 0.0.0.0 so phones on LAN can reach the API). Use 127.0.0.1 for local-only.
# BIND_HOST=0.0.0.0
# Must be a full URI (postgresql://user:pass@host:port/dbname). A bare database name causes ENOTFOUND "base".
# Local Postgres on macOS (e.g. Homebrew): there is often no `postgres` login role — use your macOS username instead:
# postgresql://yourusername@localhost:5432/deenly_dev
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DB_SSL_MODE=require
CORS_ORIGINS=https://your-web-app-domain.com
JWT_ACCESS_SECRET=replace-with-very-long-random-secret
JWT_REFRESH_SECRET=replace-with-very-long-random-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
LOG_LEVEL=info
TRUST_PROXY=true
ADMIN_OWNER_EMAIL=you@example.com
PROCESSING_WEBHOOK_TOKEN=replace-with-shared-secret-for-media-processor
# When false (default), video posts are feed-visible immediately after attach. Set true only if a worker calls POST /media/processing/post/:postId to mark video ready.
# Backfill stuck videos: UPDATE posts SET media_status = 'ready', media_processed_at = COALESCE(media_processed_at, NOW()) WHERE media_mime_type LIKE 'video/%' AND media_status = 'processing' AND media_url IS NOT NULL;
MEDIA_ASYNC_VIDEO_PROCESSING=false
MEDIA_PROVIDER=mock
MEDIA_MAX_UPLOAD_BYTES=104857600
MEDIA_ALLOWED_MIME_TYPES=video/mp4,video/quicktime,audio/mpeg,audio/wav,image/jpeg,image/png
AWS_REGION=
AWS_S3_BUCKET=
MEDIA_PUBLIC_BASE_URL=
GOOGLE_CLIENT_ID=
# Optional: OpenAI for writing assist (POST /api/v1/ai/assist/*) and business Q&A (POST /api/v1/ai/business-chat). Leave empty to disable.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Comma-separated substrings (case-insensitive) rejected in posts, comments, profiles, products, events, event chat, and registration.
COMMENT_BLOCKED_TERMS=
# Optional extra terms merged with COMMENT_BLOCKED_TERMS (same behavior).
CONTENT_BLOCKED_TERMS=
# Comma-separated hostname blocklist for http(s) links, e.g. onlyfans.com,bet365.com (also accepts full URLs; subdomains match).
BLOCKED_URL_HOSTS=
VIEW_DEDUPE_WINDOW_SECONDS=45
AUTH_LOGIN_RATE_LIMIT_WINDOW_MS=900000
AUTH_LOGIN_RATE_LIMIT_MAX=12
AUTH_REGISTER_RATE_LIMIT_WINDOW_MS=900000
AUTH_REGISTER_RATE_LIMIT_MAX=10
# Per-user rate limits for promoted-post flows (abuse protection). Skipped when NODE_ENV=test.
ADS_CAMPAIGN_CREATE_RATE_LIMIT_WINDOW_MS=900000
ADS_CAMPAIGN_CREATE_RATE_LIMIT_MAX=40
ADS_BOOST_CHECKOUT_RATE_LIMIT_WINDOW_MS=900000
ADS_BOOST_CHECKOUT_RATE_LIMIT_MAX=25
# Suppress duplicate ad_boost_live in-app notifications for the same campaign within N minutes (approve + webhook race).
AD_BOOST_LIVE_NOTIFY_DEDUPE_MINUTES=3
FEED_RANK_COMMENT_WEIGHT=120
FEED_RANK_BENEFITED_WEIGHT=60
FEED_RANK_WATCH_SECONDS_WEIGHT=1
FEED_RANK_COMPLETION_RATE_WEIGHT=2
FEED_RANK_FOLLOW_BOOST_WEIGHT=300
FEED_RANK_AFFINITY_WEIGHT=45
FEED_RANK_INTEREST_BOOST_WEIGHT=220
FEED_SPONSORED_INSERT_EVERY=6
FEED_TRUST_REPORT_PENALTY_WEIGHT=250
FEED_AUDIENCE_TAB_BOOST_WEIGHT=1
# Optional: marketplace feed rank boost from product platform_fee_bps (only when a published product is attached). Capped by FEED_RANK_PLATFORM_FEE_CAP_BPS.
FEED_RANK_PLATFORM_FEE_WEIGHT=3
FEED_RANK_PLATFORM_FEE_CAP_BPS=3500
# Additive feed rank boost from onboarding intents (community / shop / sell / b2b); score is 0–4 per post.
FEED_RANK_ONBOARDING_INTENT_WEIGHT=60
# Bounded rewards/commerce ranking modifiers (additive on rank_score). Off by default.
FEED_REWARDS_RANKING_ENABLED=false
# Hard cap on seller boost catalog `rankModifierPoints` (separate from FEED_SELLER_BOOST_RANK_CAP in SQL).
# SELLER_BOOST_RANK_MODIFIER_POINTS_CAP=500
# Optional: expose caps on GET /feed when query rankModifierAudit=1 (dev/staging only).
FEED_RANK_MODIFIERS_DEBUG=false
# Sample rate 0..1 for analytics_events row feed_ranking_modifiers_applied when modifiers are enabled.
FEED_RANK_MODIFIER_ANALYTICS_SAMPLE_RATE=0.02
FEED_RANK_MODIFIER_CAP_ENGAGEMENT=42
FEED_RANK_MODIFIER_WEIGHT_ENGAGEMENT=1
FEED_RANK_MODIFIER_CAP_BOOST_TIER=24
FEED_RANK_MODIFIER_WEIGHT_BOOST_TIER_UNIT=12
FEED_RANK_MODIFIER_CAP_SALES=16
FEED_RANK_MODIFIER_WEIGHT_SALES_LN=6
FEED_RANK_MODIFIER_COMBINED_POSITIVE_CAP=72
FEED_RANK_MODIFIER_CAP_CONVERSION=12
FEED_RANK_MODIFIER_WEIGHT_CONVERSION=10
FEED_RANK_MODIFIER_CAP_SELLER_TRUST_SUB=22
FEED_RANK_MODIFIER_WEIGHT_SELLER_REPORTS=5
FEED_RANK_MODIFIER_BOOST_MAX_FRACTION=0.38
# Engagement proxy blend inside SQL (completion / view velocity / comments+benefited); weights should sum to <= 1.
# FEED_RANK_MODIFIER_ENGAGEMENT_W_COMPLETION=0.44
# FEED_RANK_MODIFIER_ENGAGEMENT_W_VIEWS=0.28
# FEED_RANK_MODIFIER_ENGAGEMENT_W_SOCIAL=0.28
# FEED_RANK_MODIFIER_ENGAGEMENT_VIEW_CAP_DIVISOR=4000
# FEED_RANK_MODIFIER_ENGAGEMENT_SOCIAL_CAP_DIVISOR=55
# Public URL of the web app (Stripe Checkout success/cancel + Connect onboarding return). Use the same origin as Next.js (often :3001 in dev).
APP_BASE_URL=http://localhost:3000
# Webhook URL to register in Stripe Dashboard: {API_ORIGIN}/api/v1/monetization/webhooks/stripe
# Development default; use 500 (5%) in production per monetization policy.
MONETIZATION_PLATFORM_FEE_BPS=350
MONETIZATION_PLATFORM_FEE_BPS_MIN=50
MONETIZATION_PLATFORM_FEE_BPS_MAX=3500
AFFILIATE_GLOBAL_COMMISSION_BPS=700
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=
# Referrals (requires DATABASE_URL, reward_accounts migration, and Stripe charge.refunded for clawbacks). Default false.
REFERRALS_ENABLED=false
# REFERRAL_REFERRER_REWARD_POINTS_MINOR=500
# REFERRAL_HOLD_CLEAR_HOURS_AFTER_ORDER=0
# REFERRAL_QUALIFYING_ORDER_KINDS=product,support,subscription,event_ticket
# Rewards fraud-flag heuristics (admin / monetization admin rewards endpoints). Bounds enforced in env loader.
# REWARDS_FRAUD_REDEMPTION_VELOCITY_WINDOW_HOURS=24
# REWARDS_FRAUD_REDEMPTION_VELOCITY_MIN_COUNT=4
# REWARDS_FRAUD_REVERSAL_BURST_WINDOW_DAYS=7
# REWARDS_FRAUD_REVERSAL_BURST_MIN_COUNT=3
# REWARDS_FRAUD_REFERRAL_QUALIFIED_VELOCITY_WINDOW_HOURS=24
# REWARDS_FRAUD_REFERRAL_QUALIFIED_VELOCITY_MIN_COUNT=8
# REWARDS_FRAUD_VOIDED_ATTRIBUTION_WINDOW_DAYS=7
# REWARDS_FRAUD_VOIDED_ATTRIBUTION_LIST_LIMIT=40
# Checkout catalog redemption (defaults match loadEnv — override only when policy changes).
# REWARDS_CURRENCY_CODE=DEEN_PTS
# REWARDS_POINTS_DECIMALS=0
# REWARDS_MAX_EARN_PER_USER_PER_DAY_MINOR=5000
# REWARDS_MAX_EARN_PER_USER_PER_MONTH_MINOR=50000
# REWARDS_MAX_SINGLE_GRANT_MINOR=2000
# REWARDS_MIN_GRANT_MINOR=1
# REWARDS_RULES_MAX_GRANTS_PER_ROLLING_HOUR=40
# REWARDS_RULES_MIN_SECONDS_BETWEEN_GRANTS_SAME_TARGET=45
# REWARDS_RULES_MIN_QUALITY_FOR_ENGAGEMENT_EARN=0.55
# REWARDS_RULES_MIN_DWELL_SECONDS_FOR_REACTION=3
# REWARDS_REVERSAL_FULL_REFUND_CLAWBACK_RATIO=1
# REWARDS_REVERSAL_PARTIAL_REFUND_CLAWBACK_RATIO=0.5
# REWARDS_REVERSAL_CHARGEBACK_CLAWBACK_RATIO=1
# REWARDS_REVERSAL_MAX_AGE_DAYS=120
# Optional: Plaid (US) — seller bank → Stripe Connect external account. Sandbox: https://dashboard.plaid.com/overview/sandbox
PLAID_CLIENT_ID=
PLAID_SECRET=
# sandbox | development | production
PLAID_ENV=sandbox
# Strong key for encrypting Plaid access tokens at rest (32-byte base64 or 64 hex). Recommended in production.
PLAID_TOKEN_ENCRYPTION_KEY=
# Post-purchase email (SendGrid) and SMS (Twilio). Optional: fulfillment still mints access tokens if unset; email/SMS skipped.
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
PURCHASE_ACCESS_TOKEN_TTL_DAYS=14
# Set to false to disable channels without removing keys
FULFILLMENT_EMAIL_ENABLED=true
FULFILLMENT_SMS_ENABLED=true
OPS_METRICS_URL=
OPS_METRICS_BEARER_TOKEN=
# CI/local: optional floor for ops:check-metrics (skip API error rate when apiTotalRequests is below this)
OPS_METRICS_MIN_API_REQUESTS=
# ops:check-metrics: fail if p95Ms exceeds this (default 1500). Set lower (e.g. 700) when your SLO allows.
OPS_METRICS_P95_MAX_MS=
# Must be this API’s own origin (same as PORT). Mock PUT /mock-upload/* is served here — not Next.js :8080 unless you proxy.
MOCK_UPLOAD_BASE_URL=http://localhost:3000

# Instagram cross-post (Meta Graph API — Business/Creator + Facebook Page)
# META_OAUTH_REDIRECT_URI must match a valid OAuth redirect in the Meta developer app (e.g. backend callback).
META_APP_ID=
META_APP_SECRET=
META_OAUTH_REDIRECT_URI=http://localhost:3000/api/v1/instagram/oauth/callback
INSTAGRAM_GRAPH_API_VERSION=v21.0
# 32-byte key: 64 hex chars OR base64 encoding 32 raw bytes. Strongly recommended in production.
META_TOKEN_ENCRYPTION_KEY=
# Optional; defaults to JWT_REFRESH_SECRET if unset (set explicitly in production).
META_OAUTH_STATE_SECRET=

# Geocoding: GET /api/v1/geocode/search and /reverse proxy OpenStreetMap Nominatim (no API key). Respect Nominatim usage policy; the server rate-limits by IP. For heavy use, run your own Nominatim or another geocoder.

# Events (MVP → production): master switch plus granular read/create/chat. When EVENTS_FEATURE_ENABLED=false, all event routes return 404.
# Full production: set all four to true after migrations include events tables (see backend/migrations).
EVENTS_FEATURE_ENABLED=true
EVENTS_READ_ENABLED=true
EVENTS_CREATE_ENABLED=true
EVENTS_CHAT_ENABLED=true
# Hours after event end that chat stays open (host + "going" RSVPs).
EVENTS_CHAT_GRACE_HOURS=24
# Feed: how often to consider inserting an event card in For You (higher = fewer cards). Requires EVENTS_FEATURE_ENABLED and EVENTS_READ_ENABLED.
FEED_EVENT_INSERT_EVERY=8
FEED_EVENT_CANDIDATES_LIMIT=6
# Growth / experiment rollout (analytics guardrails on GET /analytics/rollout-status). Not the same as EVENTS_* flags.
ROLLOUT_STAGE=read
ROLLOUT_COHORT_PERCENT=10
ROLLOUT_GUARDRAIL_CHECKOUT_CONVERSION_MIN=0.02
ROLLOUT_GUARDRAIL_QUICK_ACTION_CTR_MIN=0.05
ROLLOUT_GUARDRAIL_OPEN_REPORTS_MAX=200
GROWTH_EXPERIMENTS_ENABLED=true

# Expo push (mobile): Expo access token from https://expo.dev/accounts/[account]/settings/access-tokens
# Required for real device push when clients register ExponentPushToken[…] with POST /notifications/push/devices.
# EXPO_ACCESS_TOKEN=
