NODE_ENV=production
PORT=3000
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DB_SSL_MODE=require
CORS_ORIGINS=https://your-web-app-domain.com
JWT_ACCESS_SECRET=replace-with-very-long-random-secret
JWT_REFRESH_SECRET=replace-with-very-long-random-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
LOG_LEVEL=info
TRUST_PROXY=true
ADMIN_OWNER_EMAIL=you@example.com
PROCESSING_WEBHOOK_TOKEN=replace-with-shared-secret-for-media-processor
# When false (default), video posts are feed-visible immediately after attach. Set true only if a worker calls POST /media/processing/post/:postId to mark video ready.
# Backfill stuck videos: UPDATE posts SET media_status = 'ready', media_processed_at = COALESCE(media_processed_at, NOW()) WHERE media_mime_type LIKE 'video/%' AND media_status = 'processing' AND media_url IS NOT NULL;
MEDIA_ASYNC_VIDEO_PROCESSING=false
MEDIA_PROVIDER=mock
MEDIA_MAX_UPLOAD_BYTES=104857600
MEDIA_ALLOWED_MIME_TYPES=video/mp4,video/quicktime,audio/mpeg,audio/wav,image/jpeg,image/png
AWS_REGION=
AWS_S3_BUCKET=
MEDIA_PUBLIC_BASE_URL=
GOOGLE_CLIENT_ID=
# Optional: OpenAI for optional writing assist (POST /api/v1/ai/assist/*). Leave empty to disable.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
COMMENT_BLOCKED_TERMS=
VIEW_DEDUPE_WINDOW_SECONDS=45
AUTH_LOGIN_RATE_LIMIT_WINDOW_MS=900000
AUTH_LOGIN_RATE_LIMIT_MAX=12
AUTH_REGISTER_RATE_LIMIT_WINDOW_MS=900000
AUTH_REGISTER_RATE_LIMIT_MAX=10
FEED_RANK_COMMENT_WEIGHT=120
FEED_RANK_BENEFITED_WEIGHT=60
FEED_RANK_WATCH_SECONDS_WEIGHT=1
FEED_RANK_COMPLETION_RATE_WEIGHT=2
FEED_RANK_FOLLOW_BOOST_WEIGHT=300
FEED_RANK_AFFINITY_WEIGHT=45
FEED_RANK_INTEREST_BOOST_WEIGHT=220
FEED_SPONSORED_INSERT_EVERY=6
FEED_TRUST_REPORT_PENALTY_WEIGHT=250
FEED_AUDIENCE_TAB_BOOST_WEIGHT=1
# Optional: marketplace feed rank boost from product platform_fee_bps (only when a published product is attached). Capped by FEED_RANK_PLATFORM_FEE_CAP_BPS.
FEED_RANK_PLATFORM_FEE_WEIGHT=3
FEED_RANK_PLATFORM_FEE_CAP_BPS=3500
# Additive feed rank boost from onboarding intents (community / shop / sell / b2b); score is 0–4 per post.
FEED_RANK_ONBOARDING_INTENT_WEIGHT=60
# Public URL of the web app (Stripe Checkout success/cancel + Connect onboarding return). Use the same origin as Next.js (often :3001 in dev).
APP_BASE_URL=http://localhost:3000
# Webhook URL to register in Stripe Dashboard: {API_ORIGIN}/api/v1/monetization/webhooks/stripe
MONETIZATION_PLATFORM_FEE_BPS=350
MONETIZATION_PLATFORM_FEE_BPS_MIN=50
MONETIZATION_PLATFORM_FEE_BPS_MAX=3500
AFFILIATE_GLOBAL_COMMISSION_BPS=700
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=
OPS_METRICS_URL=
OPS_METRICS_BEARER_TOKEN=
# CI/local: optional floor for ops:check-metrics (skip API error rate when apiTotalRequests is below this)
OPS_METRICS_MIN_API_REQUESTS=
MOCK_UPLOAD_BASE_URL=http://localhost:8080

# Instagram cross-post (Meta Graph API — Business/Creator + Facebook Page)
# META_OAUTH_REDIRECT_URI must match a valid OAuth redirect in the Meta developer app (e.g. backend callback).
META_APP_ID=
META_APP_SECRET=
META_OAUTH_REDIRECT_URI=http://localhost:8080/api/v1/instagram/oauth/callback
INSTAGRAM_GRAPH_API_VERSION=v21.0
# 32-byte key: 64 hex chars OR base64 encoding 32 raw bytes. Strongly recommended in production.
META_TOKEN_ENCRYPTION_KEY=
# Optional; defaults to JWT_REFRESH_SECRET if unset (set explicitly in production).
META_OAUTH_STATE_SECRET=
