# Backend API — only EXPO_PUBLIC_API_BASE_URL (fix typos: http://, localhost:3000 not localhost.3000).
# Simulator: http://localhost:3000/api/v1 is fine. Physical phone: use your Mac's LAN IP in this URL, e.g.
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.10:3000/api/v1
# If you omit EXPO_PUBLIC_API_BASE_URL, dev mode tries Expo's LAN host (when unset, not all setups work).
# Android emulator + localhost in this URL → 10.0.2.2 automatically.
#
# After changing this file: npx expo start -c (Metro caches env). Health check on Mac: curl http://127.0.0.1:3000/health
# On phone browser: http://<same-LAN-IP>:3000/health — must load before the app can reach the API.
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1
# EAS production/preview builds use eas.json env; matches Railway when set there:
# EXPO_PUBLIC_API_BASE_URL=https://deenly-production.up.railway.app/api/v1
# Optional; relative media keys are joined here. Absolute http://localhost:… URLs from the API are rewritten on device using your API base host.
EXPO_PUBLIC_MEDIA_PUBLIC_BASE_URL=
EXPO_PUBLIC_ADMIN_OWNER_EMAIL=you@example.com
# Public web origin (Terms, Privacy links in Settings). No trailing slash.
# Universal links / app links: https://YOUR_ORIGIN/events/123?inviteToken=… opens the native app when
# apple-app-site-association + assetlinks.json are deployed and app.json host matches this origin.
EXPO_PUBLIC_WEB_APP_URL=https://deenly.app
# Android Google Maps (react-native-maps): set in EAS as GOOGLE_MAPS_ANDROID_API_KEY so release builds show the map tiles.
# GOOGLE_MAPS_ANDROID_API_KEY=
# Optional: Sentry DSN (production). Source maps: set SENTRY_AUTH_TOKEN + org/project on EAS (see Expo Sentry guide).
# EXPO_PUBLIC_SENTRY_DSN=
# Optional: send events while in __DEV__ (default off).
# EXPO_PUBLIC_SENTRY_SEND_IN_DEV=1
# Search > Near me uses expo-location; no Google Maps API key required for the default list + external Maps link.
