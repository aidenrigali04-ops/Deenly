# Backend API (must be reachable from the phone/emulator — not "localhost" on a physical device).
# Dev: localhost is rewritten using LAN IP from Expo in LAN mode, or 10.0.2.2 on Android emulator only.
# Expo "Tunnel" uses exp.direct for Metro only — it cannot reach your machine's :3000; use LAN or set:
# EXPO_PUBLIC_DEV_MACHINE_HOST=192.168.1.10
# Or full URL: EXPO_PUBLIC_API_BASE_URL=http://192.168.1.10:3000/api/v1
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1
EXPO_PUBLIC_MEDIA_PUBLIC_BASE_URL=
EXPO_PUBLIC_ADMIN_OWNER_EMAIL=you@example.com
