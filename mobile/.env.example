# Backend API (must be reachable from the phone/emulator — not "localhost" on a physical device unless you use a tunnel).
# Dev: copy to .env — localhost is auto-rewritten from Expo (hostUri / debuggerHost) or 10.0.2.2 (Android emulator only).
# If your phone still shows "Cannot reach API at localhost", set your Mac's LAN IP (no http://):
# EXPO_PUBLIC_DEV_MACHINE_HOST=192.168.1.10
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1
EXPO_PUBLIC_MEDIA_PUBLIC_BASE_URL=
EXPO_PUBLIC_ADMIN_OWNER_EMAIL=you@example.com
