{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "types": ["jest", "node"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@deenly/rewards": ["../shared/rewards/index.ts"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "../shared/rewards/**/*.ts"],
  "exclude": [
    "node_modules",
    "../shared/rewards/**/*.test.ts",
    "../shared/rewards/vitest.config.ts"
  ]
}
