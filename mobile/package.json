    "test:e2e:smoke": "node ./scripts/e2e-smoke.js",
    "doctor": "expo-doctor",
    "verify:release-gates": "node ./scripts/verify-release-gates.js",
    "postinstall": "node ./scripts/ensure-expo-log-box-symlink.js"
  },
