    "build:android": "eas build --platform android --profile production",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "inventory:ts-prune": "npx --yes ts-prune -p tsconfig.json",
    "test": "node ./node_modules/jest/bin/jest.js",
